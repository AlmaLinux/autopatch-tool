FROM almalinux:10

RUN dnf install -y \
        python3 python3-pip python3-pyyaml \
        git rpm-build rpmdevtools \
        nodejs npm \
    && dnf clean all

RUN npm install -g @anthropic-ai/claude-code

# Install autopatch tools (validate_config, autopatch CLI)
COPY setup.py /build/setup.py
COPY src/ /build/src/
COPY autopatch_standalone.py /build/autopatch_standalone.py
COPY validate_config.py /build/validate_config.py
COPY package_patching.py /build/package_patching.py
COPY agent/Containerfile /build/agent/Containerfile
COPY agent/entrypoint.sh /build/agent/entrypoint.sh
RUN pip3 install --no-deps /build && rm -rf /build

RUN pip3 install pyyaml

RUN useradd -m -s /bin/bash agent \
    && mkdir -p /workspace/result \
    && chown -R agent:agent /workspace

# All agent files: CLAUDE.md, .claude/ (agents, skills, commands, settings)
COPY --chown=agent:agent agent/ /workspace/
RUN chmod +x /workspace/entrypoint.sh

USER agent
WORKDIR /workspace

ENTRYPOINT ["/workspace/entrypoint.sh"]
